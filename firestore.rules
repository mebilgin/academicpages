rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Pilot-only rules:
    // - Authenticated anonymous users can create/update their own session data.
    // - Reads are blocked from the browser.
    // - For the main study, replace this with Cloud Functions-only writes.

    match /studies/{studyId}/participants/{participantId} {
      allow read: if false;
      allow create, update: if request.auth != null
        && request.resource.data.firebase_uid == request.auth.uid
        && request.resource.data.participant_id == participantId;
    }

    match /studies/{studyId}/sessions/{sessionId} {
      allow read: if false;
      allow create, update: if request.auth != null
        && request.resource.data.firebase_uid == request.auth.uid
        && request.resource.data.session_id == sessionId;

      match /{subcollection}/{docId} {
        allow read: if false;
        allow create, update: if request.auth != null
          && request.resource.data.firebase_uid == request.auth.uid
          && request.resource.data.session_id == sessionId;
      }
    }
  }
}
